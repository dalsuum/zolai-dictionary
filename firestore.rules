// firestore.rules — Security rules for Zolai Dictionary
//
// To deploy these rules:
//   1. Open https://console.firebase.google.com → zolai-dictionary
//   2. Build → Firestore Database → Rules tab
//   3. Replace the default rules with this file's content
//   4. Click "Publish"

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // /edits collection — admin overlay over base words.json
    match /edits/{wordKey} {
      // Anyone can read — public dictionary needs to display the corrections
      allow read: if true;

      // Only authenticated admins listed below can write
      allow create, update, delete: if request.auth != null
        && request.auth.token.email in [
          'dalsuum08@gmail.com'
          // To add more admins, append email addresses to this list
        ];
    }

    // /config/site — global site settings (GA ID, OpenRouter key, AI model)
    // Stored here so admin's settings survive browser-data clearing
    match /config/{configId} {
      // Anyone can read — public site loads GA ID and AI config from here
      allow read: if true;

      // Only authenticated admins can write
      allow create, update, delete: if request.auth != null
        && request.auth.token.email in [
          'dalsuum08@gmail.com'
        ];
    }

    // Default deny — no other collections are accessible
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
